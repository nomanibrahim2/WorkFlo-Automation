{
  "name": "workflo_automation",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --verbose"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(expo|@expo|expo-router|react-native|@react-native|react-native-paper|react-native-vector-icons|react-native-safe-area-context|@react-native-async-storage)/)"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.5",
    "expo-auth-session": "~55.0.7",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/react-native": "^13.3.3",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "^55.0.10",
    "jest": "^30.2.0"
  }
}
